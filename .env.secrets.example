# LabOS NAT Server -- API Keys
# Copy to .env.secrets:  cp .env.secrets.example .env.secrets

# SerpAPI (for agent web search tool -- optional, falls back to DuckDuckGo)
# Get from: https://serpapi.com/
SERPAPI_KEY=

# Alibaba DashScope (only needed if using Qwen TTS provider)
DASHSCOPE_API_KEY=

# Google Gemini API key (for reason_llm -- main agent LLM)
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
